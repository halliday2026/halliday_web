<section class="who-section">
  <div class="container">
    <div class="who-header reveal">
      <p class="section-tag">Is This for You?</p>
      <h2 class="section-headline">You'll get the most from this <em>if you're...</em></h2>
    </div>

    <div class="who-grid">
      <div class="who-item reveal">
        <svg class="who-check" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
          <circle cx="12" cy="12" r="10"/>
          <path d="M9 12l2 2 4-4"/>
        </svg>
        <p class="who-text">A solo consultant or coach who needs a credible web presence</p>
      </div>

      <div class="who-item reveal">
        <svg class="who-check" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
          <circle cx="12" cy="12" r="10"/>
          <path d="M9 12l2 2 4-4"/>
        </svg>
        <p class="who-text">A small nonprofit leader tired of patching an outdated site</p>
      </div>

      <div class="who-item reveal">
        <svg class="who-check" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
          <circle cx="12" cy="12" r="10"/>
          <path d="M9 12l2 2 4-4"/>
        </svg>
        <p class="who-text">A professional services firm (attorney, advisor, therapist) who wants clients to take you seriously online</p>
      </div>

      <div class="who-item reveal">
        <svg class="who-check" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
          <circle cx="12" cy="12" r="10"/>
          <path d="M9 12l2 2 4-4"/>
        </svg>
        <p class="who-text">Anyone who'd rather pay a monthly fee than manage a website themselves</p>
      </div>
    </div>
  </div>
</section>
