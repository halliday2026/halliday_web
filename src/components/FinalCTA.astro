---
const mailto = 'mailto:web@hallidayinc.com?subject=Managed%20Website%20Program%20Inquiry';
---
<section class="cta-section" id="contact">
  <div class="container reveal">
    <p class="section-tag" style="color: rgba(42,157,143,0.85);">Get Started</p>
    <h2 class="section-headline">
      Ready for a website you don't<br />have to think about?
    </h2>
    <p class="cta-sub">
      30-minute discovery call. No pressure. Find out if the program is a fit for you.
    </p>

    <a href={mailto} class="btn btn-coral">Start the Conversation</a>

    <p class="cta-email-link">
      Or email us directly at <a href={mailto}>web@hallidayinc.com</a>
    </p>
  </div>
</section>
