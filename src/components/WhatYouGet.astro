---
---
<section class="wyg-section">
  <div class="container">
    <div class="wyg-header reveal">
      <p class="section-tag">What's Included</p>
      <h2 class="section-headline">Everything you need. <em>Nothing you don't.</em></h2>
    </div>

    <div class="wyg-grid">
      <!-- Row 1 -->
      <div class="wyg-item reveal">
        <svg class="wyg-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" aria-hidden="true">
          <path d="M12 2L2 7l10 5 10-5-10-5z"/>
          <path d="M2 17l10 5 10-5M2 12l10 5 10-5"/>
        </svg>
        <p class="wyg-label">Custom-designed site</p>
        <p class="wyg-desc">Built specifically for your brand, not a template.</p>
      </div>

      <div class="wyg-item reveal">
        <svg class="wyg-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" aria-hidden="true">
          <rect x="5" y="2" width="14" height="20" rx="2"/>
          <path d="M12 18h.01"/>
        </svg>
        <p class="wyg-label">Mobile responsive</p>
        <p class="wyg-desc">Looks great on every device, automatically.</p>
      </div>

      <div class="wyg-item reveal">
        <svg class="wyg-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" aria-hidden="true">
          <path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/>
          <circle cx="9" cy="7" r="4"/>
          <path d="M23 21v-2a4 4 0 0 0-3-3.87M16 3.13a4 4 0 0 1 0 7.75"/>
        </svg>
        <p class="wyg-label">Your content, your voice</p>
        <p class="wyg-desc">We work with your copy, photos, and style.</p>
      </div>

      <!-- Row 2 -->
      <div class="wyg-item reveal">
        <svg class="wyg-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" aria-hidden="true">
          <path d="M22 12h-4l-3 9L9 3l-3 9H2"/>
        </svg>
        <p class="wyg-label">Fast, reliable hosting</p>
        <p class="wyg-desc">Industry-standard infrastructure. No uptime surprises.</p>
      </div>

      <div class="wyg-item reveal">
        <svg class="wyg-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" aria-hidden="true">
          <rect x="3" y="11" width="18" height="11" rx="2" ry="2"/>
          <path d="M7 11V7a5 5 0 0 1 10 0v4"/>
        </svg>
        <p class="wyg-label">SSL &amp; security</p>
        <p class="wyg-desc">HTTPS, domain management, renewals — all handled.</p>
      </div>

      <div class="wyg-item reveal">
        <svg class="wyg-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" aria-hidden="true">
          <path d="M11 4H4a2 2 0 0 0-2 2v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2v-7"/>
          <path d="M18.5 2.5a2.121 2.121 0 0 1 3 3L12 15l-4 1 1-4 9.5-9.5z"/>
        </svg>
        <p class="wyg-label">Monthly updates included</p>
        <p class="wyg-desc">Text changes, new headshots, quick tweaks. Just ask.</p>
      </div>
    </div>
  </div>
</section>
